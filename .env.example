# Supabase (get from supabase.com > Your Project > Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Dev bypass: set to 'true' to skip auth in development
# VITE_DEV_BYPASS=true

# (Removed 2026-04-20) VITE_GEMINI_API_KEY is no longer used. Image-based
# exercise extraction now runs server-side via Claude Opus 4.7 on the
# `extract_exercises` edge-function op — no browser-side LLM key required.
